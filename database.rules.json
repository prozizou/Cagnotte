{
  "rules": {
    ".read": false,
    ".write": false,

    "cagnotte_db": {
      ".read": true,
      ".write": true,
      "$donId": {
        ".validate": "newData.hasChildren(['name','amount'])",
        "name":   { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "amount": { ".validate": "newData.isNumber() && newData.val() > 0" },
        "ts":     { ".validate": "newData.isNumber()" },
        "$autre": { ".validate": false }
      }
    },

    "menages": {
      ".read": true,
      ".write": "auth != null",
      "$menageId": {
        ".validate": "newData.hasChildren(['name'])",
        "name":                { ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 100" },
        "monthlyContribution": { ".validate": "newData.isNumber() && newData.val() >= 0" },
        "status":              { ".validate": "newData.val() === 'active' || newData.val() === 'inactive'" },
        "paymentMethod":       { ".validate": "newData.isString() && newData.val().length <= 40" },
        "createdAt":           { ".validate": "newData.isNumber()" },
        "dernierMoisPaye":     { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}$/)" },
        "$autre":              { ".validate": false }
      }
    },

    "contributions": {
      ".read": true,
      ".write": "auth != null",
      "$mois": {
        ".validate": "$mois.matches(/^[0-9]{4}-[0-9]{2}$/)",
        "$paiementId": {
          ".validate": "newData.hasChildren(['menage','montant','type','date'])",
          "menage":  { ".validate": "newData.isString() && newData.val().length <= 100" },
          "montant": { ".validate": "newData.isNumber() && newData.val() > 0" },
          "type":    { ".validate": "newData.val() === 'cotisation' || newData.val() === 'soutien'" },
          "waveRef": { ".validate": "newData.isString() && newData.val().length <= 160" },
          "date":    { ".validate": "newData.isNumber()" },
          "$autre":  { ".validate": false }
        }
      }
    },

    "depenses": {
      ".read": true,
      ".write": "auth != null",
      "$mois": {
        ".validate": "$mois.matches(/^[0-9]{4}-[0-9]{2}$/)",
        "$depenseId": {
          ".validate": "newData.hasChildren(['montant','date'])",
          "categorie": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "libelle":   { ".validate": "newData.isString() && newData.val().length <= 160" },
          "montant":   { ".validate": "newData.isNumber() && newData.val() > 0" },
          "date":      { ".validate": "newData.isNumber()" },
          "$autre":    { ".validate": false }
        }
      }
    },

    "stats": {
      ".read": true,
      ".write": "auth != null",
      "global": {
        "cumul":      { ".validate": "newData.isNumber()" },
        "lastUpdate": { ".validate": "newData.isNumber()" },
        "$autre":     { ".validate": false }
      }
    },

    "admins": {
      ".read": false,
      ".write": false
    },

    "processed_payments": {
      ".read": false,
      ".write": false
    }
  }
}
